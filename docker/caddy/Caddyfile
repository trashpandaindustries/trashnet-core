# Caddyfile - LAN passthrough + WAN stub

# LAN access (no auth overhead)
:80 {
    # API endpoints route to the Node backend
    handle /api/* {
        reverse_proxy api:3000 {
            header_up X-Trashnet-Context "LAN"
        }
    }

    # All other requests route to the React SPA
    handle {
        reverse_proxy web:80 {
            header_up X-Trashnet-Context "LAN"
        }
    }
}

# WAN access (TLS termination + Authelia stub)
# The stub will be replaced with Authelia forward_auth later.
:443 {
    tls internal # using internal certs for now

    handle /api/* {
        reverse_proxy api:3000 {
            header_up X-Trashnet-Context "WAN"
        }
    }
    
    handle {
        reverse_proxy web:80 {
            header_up X-Trashnet-Context "WAN"
        }
    }
}
